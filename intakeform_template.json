            { "id": "aggressive", "label": "Aggressive" },
            { "id": "wants_alone", "label": "Wants to Be Left Alone" },
            { "id": "sensitive", "label": "Sensitive" },
            { "id": "playful", "label": "Playful" },
            { "id": "severe_tantrums", "label": "Severe Tantrums" },
            { "id": "slow_warm_up", "label": "Slow to Warm Up" },
            { "id": "fearful", "label": "Fearful" },
            { "id": "curious", "label": "Curious" },
            { "id": "staring_spells", "label": "Staring Spells" },
            { "id": "breath_holding", "label": "Breath Holding Spells" },
            { "id": "happy", "label": "Happy" },
            { "id": "head_banging", "label": "Head Banging" },
            { "id": "stuttering", "label": "Stuttering" },
            { "id": "sad", "label": "Sad" },
            { "id": "irritable", "label": "Irritable" }
          ]
        }
      ]
    },
    {
      "id": "current_behaviors",
      "title": "Current Behaviors",
      "fields": [
        { "id": "self_esteem_concerns", "label": "Do you have any concerns about your child's self-esteem?", "type": "textarea" },
        { "id": "sexual_knowledge", "label": "Sexual knowledge or awareness", "type": "textarea" },
        { "id": "gender_identity", "label": "Gender Identity", "type": "text" },
        { "id": "sexual_orientation", "label": "Sexual Orientation", "type": "text" },
        {
          "id": "current_behaviors_checklist",
          "label": "Please select any of the following that this child currently demonstrates",
          "type": "checkboxGroup",
          "options": [
            { "id": "bedwetting", "label": "Bedwetting" },
            { "id": "immaturity", "label": "Immaturity" },
            { "id": "involuntary_vocalizations", "label": "Involuntary Vocalizations" },
