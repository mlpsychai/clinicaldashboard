{
  "formTitle": "Pediatric Registration",
  "formVersion": "1.0",
  "sections": [
    {
      "id": "patient_info",
      "title": "Patient Information",
      "fields": [
        { "id": "patient_name", "label": "Patient's Name", "type": "text", "required": true },
        { "id": "birthdate", "label": "Birthdate", "type": "date", "required": true },
        { "id": "street_address", "label": "Street Address", "type": "text", "required": true },
        { "id": "city", "label": "City", "type": "text", "required": true },
        { "id": "state", "label": "State", "type": "text", "required": true },
        { "id": "zip", "label": "Zip", "type": "text", "required": true },
        { "id": "sex", "label": "Sex", "type": "select", "options": ["M", "F"], "required": true },
        { "id": "parent_names_ages", "label": "Parent's Names/Ages", "type": "text", "required": true },
        { "id": "other_caregiver", "label": "Other Caregiver's Name and Relationship to Patient", "type": "text" },
        { "id": "contact_email", "label": "Contact Email", "type": "email", "required": true },
        { "id": "home_phone", "label": "Home Phone", "type": "tel" },
        { "id": "mobile_phone", "label": "Mobile Phone", "type": "tel", "required": true },
        { "id": "emergency_contacts", "label": "Emergency Contacts", "type": "textarea", "required": true }
      ]
    },
    {
      "id": "insurance",
      "title": "Insurance Information",
      "fields": [
        { "id": "insurance_company", "label": "Insurance Company", "type": "text" },
        { "id": "plan_name", "label": "Plan Name", "type": "text" },
        { "id": "member_id", "label": "Member ID #", "type": "text" },
        { "id": "group_number", "label": "Group #", "type": "text" },
        { "id": "employer_school", "label": "Employer/School Name", "type": "text" },
        { "id": "valid_from", "label": "Valid From", "type": "date" },
        { "id": "valid_until", "label": "Valid Until", "type": "date" },
        { "id": "is_primary", "label": "Is this primary insurance?", "type": "select", "options": ["Yes", "No"] },
        { "id": "insured_relation", "label": "Insured Person's Relation to Patient", "type": "text" },
        { "id": "insured_name", "label": "Insured Person's Name", "type": "text" },
        { "id": "insured_dob", "label": "Insured Person's DOB", "type": "date" },
        { "id": "insured_address", "label": "Insured Person's Address (if different)", "type": "text" },
        { "id": "insured_city", "label": "City", "type": "text" },
        { "id": "insured_state", "label": "State", "type": "text" },
        { "id": "insured_zip", "label": "Zip", "type": "text" }
      ]
    },
    {
      "id": "referral",
      "title": "Referral",
      "fields": [
        { "id": "how_heard", "label": "How did you hear about us?", "type": "text" },
        { "id": "reason_for_visit", "label": "Reason for Office Visit", "type": "textarea", "required": true }
      ]
    },
    {
      "id": "child_info",
      "title": "Child Information",
      "fields": [
        { "id": "child_strengths", "label": "Tell me about your child's strengths", "type": "textarea" },
        { "id": "diagnosis_explanations", "label": "Diagnosis or explanations given to you about your child", "type": "textarea" },
        { "id": "describe_child", "label": "Please describe your child (attach more information if necessary)", "type": "textarea" },
        { "id": "first_noticed_problems", "label": "When did you first notice your child's problems?", "type": "textarea" },
        { "id": "what_first_noticed", "label": "What things did you first notice?", "type": "textarea" },
        { "id": "sudden_or_gradual", "label": "Did this happen suddenly or gradually?", "type": "select", "options": ["Suddenly", "Gradually"] },
        { "id": "contributing_factors", "label": "Was there anything that may have contributed to this problem?", "type": "textarea" }
      ]
    },
    {
      "id": "living_situation",
      "title": "Current Living Situation",
      "fields": [
        { "id": "living_with", "label": "Who is the child presently living with (biomother, stepfather, etc.)?", "type": "textarea" },
        { "id": "household_members", "label": "How many people are in the current household? Please list ages, names, relationships", "type": "textarea" },
        { "id": "home_stressors", "label": "Are there any current stressors in the home (marital, violence, drug abuse)?", "type": "textarea" },
        { "id": "is_adopted", "label": "Is the child adopted? If so, describe age of adoption and circumstances", "type": "textarea" }
      ]
    },
    {
      "id": "parents",
      "title": "Parents",
      "fields": [
        {
          "id": "marital_status",
          "label": "How long have the parents been:",
          "type": "checkboxGroup",
          "options": [
            { "id": "married", "label": "Married", "hasDetail": true, "detailLabel": "Duration" },
            { "id": "separated", "label": "Separated", "hasDetail": true, "detailLabel": "Duration" },
            { "id": "divorced", "label": "Divorced", "hasDetail": true, "detailLabel": "Duration" },
            { "id": "widowed", "label": "Widowed", "hasDetail": true, "detailLabel": "Duration" },
            { "id": "living_together", "label": "Living Together", "hasDetail": true, "detailLabel": "Duration" }
          ]
        },
        { "id": "custody_details", "label": "If separated or divorced, describe custody (physical or legal) and visitation rights", "type": "textarea" },
        { "id": "current_relationship", "label": "If married, please describe current relationship", "type": "textarea" },
        { "id": "previous_marriages", "label": "Please list any previous marriages", "type": "textarea" }
      ]
    },
    {
      "id": "biological_mother",
      "title": "Biological Mother",
      "fields": [
        { "id": "mother_name", "label": "Name", "type": "text" },
        { "id": "mother_age", "label": "Age", "type": "number" },
        { "id": "mother_education", "label": "Education Level", "type": "text" },
        { "id": "mother_occupation", "label": "Occupation", "type": "text" },
        { "id": "mother_family_medical", "label": "Do any medical illnesses run in her family?", "type": "textarea" },
        {
          "id": "mother_family_history",
          "label": "Has the biological mother or any of her relatives ever had any of the following illnesses? (list self or relation)",
          "type": "fieldGroup",
          "fields": [
            { "id": "mother_depression", "label": "Depression", "type": "text" },
            { "id": "mother_autism", "label": "Autism", "type": "text" },
            { "id": "mother_suicide_attempts", "label": "Suicide Attempts", "type": "text" },
            { "id": "mother_intellectual_disability", "label": "Intellectual Disability", "type": "text" },
            { "id": "mother_anxiety", "label": "Anxiety Disorders", "type": "text" },
            { "id": "mother_attention", "label": "Attention Problems", "type": "text" },
            { "id": "mother_psychosis", "label": "Psychosis or Thought Problems", "type": "text" },
            { "id": "mother_learning_disabilities", "label": "Learning Disabilities", "type": "text" },
            { "id": "mother_aggression", "label": "Aggression", "type": "text" },
            { "id": "mother_abuse", "label": "Physical or Sexual Abuse", "type": "text" },
            { "id": "mother_alcohol", "label": "Alcohol Abuse", "type": "text" },
            { "id": "mother_substance", "label": "Substance Abuse", "type": "text" },
            { "id": "mother_bipolar", "label": "Bipolar Disorder", "type": "text" },
            { "id": "mother_legal", "label": "Legal Trouble", "type": "text" }
          ]
        }
      ]
    },
    {
      "id": "biological_father",
      "title": "Biological Father",
      "fields": [
        { "id": "father_name", "label": "Name", "type": "text" },
        { "id": "father_age", "label": "Age", "type": "number" },
        { "id": "father_education", "label": "Education Level", "type": "text" },
        { "id": "father_occupation", "label": "Occupation", "type": "text" },
        { "id": "father_family_medical", "label": "Do any medical illnesses run in his family?", "type": "textarea" },
        {
          "id": "father_family_history",
          "label": "Has the biological father or any of his relatives ever had any of the following illnesses? (list self or relation)",
          "type": "fieldGroup",
          "fields": [
            { "id": "father_depression", "label": "Depression", "type": "text" },
            { "id": "father_autism", "label": "Autism", "type": "text" },
            { "id": "father_suicide_attempts", "label": "Suicide Attempts", "type": "text" },
            { "id": "father_intellectual_disability", "label": "Intellectual Disability", "type": "text" },
            { "id": "father_anxiety", "label": "Anxiety Disorders", "type": "text" },
            { "id": "father_attention", "label": "Attention Problems", "type": "text" },
            { "id": "father_psychosis", "label": "Psychosis or Thought Problems", "type": "text" },
            { "id": "father_learning_disabilities", "label": "Learning Disabilities", "type": "text" },
            { "id": "father_aggression", "label": "Aggression", "type": "text" },
            { "id": "father_abuse", "label": "Physical or Sexual Abuse", "type": "text" },
            { "id": "father_alcohol", "label": "Alcohol Abuse", "type": "text" },
            { "id": "father_substance", "label": "Substance Abuse", "type": "text" },
            { "id": "father_bipolar", "label": "Bipolar Disorder", "type": "text" },
            { "id": "father_legal", "label": "Legal Trouble", "type": "text" }
          ]
        }
      ]
    },
    {
      "id": "siblings",
      "title": "Brothers and Sisters",
      "description": "Indicate if step-brother or step-sister",
      "fields": [
        {
          "id": "siblings_table",
          "label": "Siblings",
          "type": "repeatingGroup",
          "maxEntries": 10,
          "fields": [
            { "id": "sibling_name", "label": "Name", "type": "text" },
            { "id": "sibling_age", "label": "Age", "type": "number" },
            { "id": "sibling_sex", "label": "Sex", "type": "select", "options": ["M", "F"] },
            { "id": "sibling_school_occupation", "label": "School or Occupation", "type": "text" },
            { "id": "sibling_grade", "label": "Present Grade", "type": "text" },
            { "id": "sibling_at_home", "label": "Living at Home", "type": "select", "options": ["Yes", "No"] },
            { "id": "sibling_drug_use", "label": "Uses Drugs or Alcohol", "type": "select", "options": ["Yes", "No"] },
            { "id": "sibling_drug_treatment", "label": "Treated for Drug Abuse", "type": "select", "options": ["Yes", "No"] }
          ]
        },
        { "id": "sibling_conflicts", "label": "Have there been any significant conflicts between this child and his/her siblings? If so, please describe", "type": "textarea" }
      ]
    },
    {
      "id": "birth_history",
      "title": "Birth History",
      "fields": [
        { "id": "mother_age_at_birth", "label": "Mother's age at time of birth", "type": "number" },
        { "id": "father_age_at_birth", "label": "Father's age at time of birth", "type": "number" },
        { "id": "smoked_during_pregnancy", "label": "Did the mother ever smoke during pregnancy?", "type": "select", "options": ["Yes", "No"] },
        { "id": "cigarettes_per_day", "label": "Cigarettes per day", "type": "text", "visibleWhen": { "field": "smoked_during_pregnancy", "equals": "Yes" } },
        { "id": "alcohol_during_pregnancy", "label": "Was alcohol ever consumed during pregnancy?", "type": "select", "options": ["Yes", "No"] },
        { "id": "drinks_per_day", "label": "If yes, how many drinks per day?", "type": "text", "visibleWhen": { "field": "alcohol_during_pregnancy", "equals": "Yes" } },
        { "id": "drugs_during_pregnancy", "label": "Were any drugs used during pregnancy?", "type": "select", "options": ["Yes", "No"] },
        { "id": "drugs_details", "label": "If so, please list type and amount consumed", "type": "textarea", "visibleWhen": { "field": "drugs_during_pregnancy", "equals": "Yes" } },
        { "id": "pregnancy_complications", "label": "Were there any complications during the pregnancy?", "type": "textarea" },
        { "id": "premature_or_late", "label": "Was the child premature or late?", "type": "text" },
        { "id": "stress_trauma_exposure", "label": "Were there any exposures of mother to stress, physical trauma, or abuse?", "type": "textarea" },
        { "id": "cesarean", "label": "Was birth a cesarean section?", "type": "select", "options": ["Yes", "No"] },
        { "id": "normally_active", "label": "Was the child normally active?", "type": "select", "options": ["Yes", "No"] },
        { "id": "birth_weight", "label": "Baby's birth weight", "type": "text" },
        { "id": "apgar_scores", "label": "Apgar Scores", "type": "text" },
        { "id": "defects_at_birth", "label": "Were there any defects noted at birth?", "type": "textarea" },
        { "id": "parent_adjustment_problems", "label": "Did either parent have any problems adjusting to the birth of your child?", "type": "select", "options": ["Yes", "No"] },
        { "id": "parent_adjustment_details", "label": "If yes, please describe", "type": "textarea", "visibleWhen": { "field": "parent_adjustment_problems", "equals": "Yes" } },
        { "id": "early_separations", "label": "Were there any physical or emotional separations from the caregivers in the first years of life?", "type": "textarea" }
      ]
    },
    {
      "id": "infancy_period",
      "title": "Infancy Period",
      "description": "Infancy, toddler, preschool period",
      "fields": [
        {
          "id": "infancy_conditions",
          "label": "Circle all that apply",
          "type": "checkboxGroup",
          "options": [
            { "id": "jaundice", "label": "Jaundice" },
            { "id": "diarrhea", "label": "Diarrhea" },
            { "id": "constipation", "label": "Constipation" },
            { "id": "eating_problems", "label": "Eating Problems" },
            { "id": "hyperactive", "label": "Hyperactive" },
            { "id": "growing_pains", "label": "Growing Pains" },
            { "id": "anemia", "label": "Anemia" },
            { "id": "asthma", "label": "Asthma" },
            { "id": "bed_wetting", "label": "Bed Wetting" },
            { "id": "tantrums", "label": "Tantrums" },
            { "id": "defiance", "label": "Defiance" },
            { "id": "fears", "label": "Fears" },
            { "id": "early_puberty", "label": "Early Puberty" },
            { "id": "warts", "label": "Warts" },
            { "id": "nightmares", "label": "Nightmares" },
            { "id": "stomach_aches", "label": "Stomach Aches" }
          ]
        },
        { "id": "breastfeed", "label": "Did the child breastfeed?", "type": "select", "options": ["Yes", "No"] },
        { "id": "breastfeed_duration", "label": "For how long?", "type": "text", "visibleWhen": { "field": "breastfeed", "equals": "Yes" } },
        { "id": "formula_start", "label": "When was child put on formula?", "type": "text" },
        { "id": "postpartum_depression", "label": "Did mother have problems with depression after birth?", "type": "select", "options": ["Yes", "No"] },
        { "id": "postpartum_details", "label": "If yes, please explain", "type": "textarea", "visibleWhen": { "field": "postpartum_depression", "equals": "Yes" } }
      ]
    },
    {
      "id": "developmental_history",
      "title": "Developmental History",
      "fields": [
        { "id": "first_words_age", "label": "Speech: First words (age)", "type": "text" },
        { "id": "first_sentences_age", "label": "Speech: First sentences (age)", "type": "text" },
        { "id": "phrases_age", "label": "Speech: Phrases (age)", "type": "text" },
        { "id": "sitting_age", "label": "Motor: Sitting up (age)", "type": "text" },
        { "id": "crawling_age", "label": "Motor: Crawling (age)", "type": "text" },
        { "id": "standing_age", "label": "Motor: Pulling/Standing (age)", "type": "text" },
        { "id": "walking_age", "label": "Motor: Walking (age)", "type": "text" },
        { "id": "self_help_skills", "label": "Self Help Skills", "type": "select", "options": ["Average", "Early", "Late"] },
        { "id": "bowel_trained_age", "label": "Bowel trained (age)", "type": "text" },
        { "id": "bladder_trained_age", "label": "Bladder trained (age)", "type": "text" },
        { "id": "started_reading_age", "label": "Started to read (age)", "type": "text" },
        { "id": "more_accidents", "label": "Does this child have more accidents than other children?", "type": "textarea" },
        { "id": "athletic_abilities", "label": "Athletic abilities", "type": "text" },
        { "id": "handedness", "label": "Handedness", "type": "select", "options": ["Left", "Right", "Both"] },
        { "id": "not_enjoy_cuddling", "label": "Not enjoy cuddling", "type": "text" },
        { "id": "difficult_to_comfort", "label": "Was difficult to comfort", "type": "text" },
        { "id": "was_colicky", "label": "Was colicky", "type": "text" },
        { "id": "excessively_restless", "label": "Was excessively restless", "type": "text" },
        { "id": "excessively_irritable", "label": "Was excessively irritable", "type": "text" },
        { "id": "sleep_difficulties", "label": "Had sleep difficulties", "type": "text" },
        { "id": "feeding_difficulties", "label": "Difficulty feeding or nursing", "type": "text" }
      ]
    },
    {
      "id": "environmental_exposures",
      "title": "Environmental Exposures",
      "fields": [
        { "id": "polluted_area", "label": "Has this child or mother while pregnant ever lived near a refinery, polluted area, or in a home with lead paint?", "type": "textarea" },
        { "id": "new_carpeting_paint", "label": "Has this child ever lived in a house that had new carpeting, paint, or other items that seem to affect the child's health?", "type": "textarea" },
        { "id": "sensitive_perfumes_dyes", "label": "Does the child seem sensitive to perfumes or dyes?", "type": "text" },
        { "id": "pesticides_chemicals", "label": "Are pesticides, herbicides, or other chemicals used around your home?", "type": "textarea" },
        { "id": "house_year_built", "label": "What year was your apt/house built?", "type": "text" },
        {
          "id": "live_near",
          "label": "Do you live near any of the following?",
          "type": "checkboxGroup",
          "options": [
            { "id": "swamp", "label": "Swamp" },
            { "id": "river", "label": "River" },
            { "id": "power_lines", "label": "High Voltage Power Lines" },
            { "id": "industrial_area", "label": "Industrial Area" },
            { "id": "large_city", "label": "Large City" }
          ]
        },
        { "id": "flooring_type", "label": "Type of flooring child spends most time around", "type": "text" }
      ]
    },
    {
      "id": "early_behaviors",
      "title": "Behaviors (Infancy, Toddler, Preschool)",
      "fields": [
        {
          "id": "early_behaviors_checklist",
          "label": "Select all that apply",
          "type": "checkboxGroup",
          "options": [
            { "id": "adaptable", "label": "Adaptable" },
            { "id": "rocking", "label": "Rocking" },
            { "id": "plays_alone", "label": "Able to Play Alone" },
            { "id": "attention_difficulty", "label": "Difficulty with Attention" },
            { "id": "easy_to_manage", "label": "Easy to Manage" },
            { "id": "underactive", "label": "Underactive/Passive" },
            { "id": "deals_frustration", "label": "Deals with Frustration" },
